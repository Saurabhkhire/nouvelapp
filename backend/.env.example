# Copy to .env and fill in. The app runs fully without these (rule-based fallback),
# but setting OPENAI_API_KEY unlocks true AI personalization.

PORT=4000
JWT_SECRET=change-me-to-a-long-random-string
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Path to the sqlite file. Defaults to ./data/nouvel.db
DB_PATH=./data/nouvel.db

# Invite control. Leave blank for open signup. To restrict who can create an
# account (the "add their email" behaviour), list approved emails, comma-separated:
# ALLOWED_EMAILS=tester1@example.com, tester2@example.com
ALLOWED_EMAILS=
